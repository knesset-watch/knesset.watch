# Copy this file to .env.local and fill in real values.
# Ask Dror for credentials, or pull from Vercel: `vercel env pull` (when CLI installed).
# NEVER commit a real .env.local — `.env*` is gitignored.

# --- Site auth ---
# Password gate that guards every page. Normalized to lowercase server-side.
SITE_PASSWORD=
# Used to sign the auth cookie. Any sufficiently long random string.
SESSION_SECRET=

# --- Turso (libSQL) — protocol RAG, vector indexes ---
TURSO_URL=libsql://your-database.turso.io
TURSO_TOKEN=

# --- Google Gemini — LLM + Google Search grounding ---
GEMINI_API_KEY=

# --- Jina AI — 256-dim text embeddings ---
JINA_API_KEY=

# --- Groq — secondary LLM ---
GROQ_API_KEY=

# --- Upstash Redis — Ask API response cache (TTL 2h) ---
# In production these are auto-provisioned by Vercel's KV integration as KV_REST_API_*.
# Either pair works; code checks both.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Knesset OData proxy (Fly.io) ---
# Set to https://knesset-proxy.fly.dev in prod to bypass Knesset's IP block.
# Leave unset locally to hit knesset.gov.il directly.
KNESSET_PROXY_URL=
# Used by sync scripts (same purpose).
KNESSET_API_BASE=

# --- Optional ---
# Used when deploying under a sub-path. Leave empty for root deploys.
NEXT_PUBLIC_BASE_PATH=
