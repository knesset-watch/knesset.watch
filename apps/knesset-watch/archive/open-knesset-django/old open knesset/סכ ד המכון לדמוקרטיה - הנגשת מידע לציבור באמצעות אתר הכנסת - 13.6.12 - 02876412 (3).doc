\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\lang1037\b\f3\rtlch\'f4\'f8\'f1\'e5\'ed \'ee\'f1\'ee\'eb\'e9\'ed \'e4\'ee\'e5\'e2\'f9\'e9\'ed \'ec\'e5\'e5\'f2\'e3\'e5\'fa \'e4\'eb\'f0\'f1\'fa\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\li720\qj\tx720\lang1037\b0\f3\rtlch\'ec\'e0 \'ee\'fa\'f4\'f8\'f1\'ee\'e9\'ed \'ee\'f1\'ee\'eb\'e9\'ed \'e4\'ee\'e5\'e2\'f9\'e9\'ed \'ec\'e5\'e5\'f2\'e3\'e5\'fa \'e4\'eb\'f0\'f1\'fa \'ec\'f7\'f8\'e0\'fa \'e3\'e9\'e5\'f0\'e9\'e4\'ef\lang1033\f2\ltrch , \lang1037\f3\rtlch\'ee\'ec\'e1\'e3 \'ee\'f1\'ee\'eb\'e9\'ed \'f9\'f0\'eb\'fa\'e1\'e5 \'e1\'e9\'e3\'e9 \'e4\'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee\lang1033\f2\ltrch .\cell\cf4\lang1037\f3\rtlch\'e1\'e0\'fa\'f8 \'e4\'e0\'e9\'f0\'e8\'f8\'f0\'e8 \'e9\'fa\'f4\'f8\'f1\'ee\'e5\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e1\'f6\'ee\'e5\'e3 \'ec\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec \'eb\'ec \'e9\'f9\'e9\'e1\'e4 \'e5\'ec\'ee\'f1\'ee\'ea \'e4\'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee \'f9\'f0\'eb\'fa\'e1 \'ec\'f7\'f8\'e0\'fa\'e4 \lang1033\f2\ltrch (\lang1037\f3\rtlch\'e0\'ed \'f0\'eb\'fa\'e1\lang1033\f2\ltrch ), \lang1037\f3\rtlch\'eb\'ec \'e4\'ee\'f1\'ee\'eb\'e9\'ed \'f9\'e4\'e5\'e2\'f9\'e5 \'ec\'e5\'e5\'f2\'e3\'e4 \'ec\'f7\'f8\'e0\'fa \'e4\'e9\'f9\'e9\'e1\'e4\lang1033\f2\ltrch .\par
\cf2\cell\pard\intbl\ltrpar\li720\qr\tx720\cf0\lang1037\f3\rtlch\'eb\'e1\'f8 \'e4\'e9\'e5\'ed  \'e7\'e5\'ee\'f8 \'f8\'e1 \'e4\'ee\'e2\'e9\'f2 \'ec\'e5\'e5\'f2\'e3\'e5\'fa \'ee\'f2\'ec\'e9 \'ee\'f6\'e5\'f8\'f3 \'eb\'e7\'e5\'ee\'f8 \'f8\'f7\'f2 \'ec\'f7\'f8\'e0\'fa \'e4\'e3\'e9\'e5\'f0\'e9\'ed \'e5\'f0\'e9\'fa\'ef \'ec\'f8\'e0\'e5\'fa \'e0\'fa \'e7\'e5\'ee\'f8\'e9 \'e4\'f8\'f7\'f2 \'e1\'f6\'ee\'e5\'e3 \'ec\'f1\'e3\'f8\'e9\lang1033\f2\ltrch -\lang1037\f3\rtlch\'e4\'e9\'e5\'ed\lang1033\f2\ltrch . \par
\lang1037\f3\rtlch\'e1\'f0\'e5\'f1\'f3 \'f7\'e9\'e9\'ee\'fa \'f4\'ec\'e8\'f4\'e5\'f8\'ee\'e4 \'ec\'f9\'e9\'fa\'e5\'f3 \'e4\'f6\'e9\'e1\'e5\'f8 \'f9\'ee\'e5\'f4\'f2\'ec\'fa \'e1\'e4\'fa\'e0\'ed \'ec\'e3\'f8\'e9\'f9\'e5\'fa \'e4\'e3\'f8\'e2 \'e4\'f4\'e5\'ec\'e9\'e8\'e9 \'eb\'e2\'e5\'ef\lang1033\f2\ltrch : \lang1037\f3\rtlch\'e1\'e5\'e5\'f2\'e3\'fa \'e4\'f4\'f0\'e9\'ed \'f9\'e1\'e4 \'e4\'fa\'e0\'f4\'f9\'f8 \'ec\'f6\'e9\'e1\'e5\'f8 \'e4\'f8\'e7\'e1 \'ec\'e4\'e2\'e9\'f9 \'e7\'e5\'ee\'f8\'e9 \'f8\'f7\'f2 \'e5\'f0\'e9\'e9\'f8\'e5\'fa \'f2\'ee\'e3\'e4 \'e1\'f0\'e5\'f9\'e0 \'fa\'f7\'f0\'e5\'fa \'e1\'f8\'e9\'e0\'e5\'fa \'e4\'f2\'ed\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e5\'e1\'f0\'e5\'f9\'e0 \'e7\'e5\'f7 \'e4\'fa\'eb\'f0\'e5\'ef \'e5\'e4\'e1\'f0\'e9\'e9\'e4 \'e5\'e1\'f0\'e5\'f9\'e0 \'e7\'e5\'f7 \'e0\'e5\'e5\'e9\'f8 \'f0\'f7\'e9\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e5\'f2\'e5\'e3\lang1033\f2\ltrch ..\par
\pard\intbl\ltrpar\qj\cf2\lang1037\f0\rtlch\'e4\'f4\'ec\'e8\'f4\'e5\'f8\'ee\'e4 \'fa\'e5\'f8\'e7\'e1 \'eb\'e7\'ec\'f7 \'ee\'fa\'eb\'f0\'e9\'fa \'e4\'f2\'e1\'e5\'e3\'e4  \'f9\'ec \'e4\'e0\'fa\'f8 \'e4\'e7\'e3\'f9\lang1033\f1\ltrch .\par
\lang1037\f0\rtlch\'f4\'f8\'f1\'e5\'ed \'e1\'f4\'e5\'f2\'ec \'e9\'e4\'e9\'e4 \'e1\'e4\'fa\'e0\'ed \'ec\'f9\'e9\'f7\'e5\'ec \'e3\'f2\'fa\'e5 \'f9\'ec \'e9\'e5\lang1033\f1\ltrch "\lang1037\f0\rtlch\'f8 \'e4\'e5\'e5\'f2\'e3\'e4 \'e0\'e5 \'ee\'f0\'e4\'ec\'e4\lang1033\f1\ltrch .\cell\cell\row\trowd\trgaph108\trleft-108\trqr\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3
\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\lang1037\b\f3\rtlch\'f9\'e0\'e9\'ec\'fa\'e5\'fa\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\li720\qr\tx720\tx1526\lang1037\b0\f3\rtlch\'eb\'ec\'ec\'e9 \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'e1\'e9\'e3\'e9 \'e4\'eb\'f0\'f1\'fa \'ee\'f6\'e5\'e9 \'ee\'f1\'ee\'ea\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f9\'e0\'e9\'f0\'e5 \'ee\'f4\'e5\'f8\'f1\'ed \'ec\'f6\'e9\'e1\'e5\'f8 \'e4\'f8\'e7\'e1\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'ee\'f8\'eb\'e6 \'e0\'fa \'e4\'f9\'e0\'e9\'ec\'fa\'e5\'fa \'f9\'e4\'e5\'e2\'f9\'e5 \'e1\'ee\'e4\'ec\'ea \'eb\'e4\'e5\'f0\'fa \'e4\'eb\'f0\'f1\'fa \'e4\'ee\'eb\'e4\'f0\'fa\lang1033\f2\ltrch . \lang1037\f3\rtlch\'e4\'ee\'f1\'ee\'ea \'eb\'e5\'ec\'ec \'e0\'fa \'e4\'f4\'f8\'e8\'e9\'ed \'e4\'e1\'e0\'e9\'ed\lang1033\f2\ltrch : \lang1037\f3\rtlch\'f1\'e5\'e2 \'e4\'f9\'e0\'e9\'ec\'fa\'e4 \lang1033\f2\ltrch (\lang1037\f3\rtlch\'f8\'e2\'e9\'ec\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e3\'e7\'e5\'f4\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e9\'f9\'e9\'f8\'e4\lang1033\f2\ltrch ), \lang1037\f3\rtlch\'ee\'f1\'f4\'f8 \'e4\'f9\'e0\'e9\'ec\'fa\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f0\'e5\'f9\'e0 \'e4\'f9\'e0\'e9\'ec\'fa\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e9\'e5\'e6\'ed \'e4\'f9\'e0\'e9\'ec\'fa\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f1\'e8\'e8\'e5\'f1 \lang1033\f2\ltrch (\lang1037\f3\rtlch\'f0\'f2\'f0\'fa\'e4\lang1033\f2\ltrch\\\lang1037\f3\rtlch\'e1\'e8\'e9\'f4\'e5\'ec \'e4\'ee\'f9\'f8\'e3 \'e4\'f0\'f9\'e0\'ec\lang1033\f2\ltrch ), \lang1037\f3\rtlch\'e4\'fa\'e0\'f8\'e9\'ea \'f9\'e1\'e4 \'f0\'f2\'f0\'fa\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'fa\'e0\'f8\'e9\'ea \'e4\'e2\'f9\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'f9\'f8 \'e4\'ee\'f9\'e9\'e1 \'e5\'f1\'e5\'e2 \'e4\'fa\'f9\'e5\'e1\'e4 \lang1033\f2\ltrch (\lang1037\f3\rtlch\'e4\'ee\'ec\'e9\'e0\'e4\lang1033\f2\ltrch\\\lang1037\f3\rtlch\'e1\'eb\'fa\'e1\lang1033\f2\ltrch ).\par
\lang1037\f3\rtlch\'e4\'ee\'e9\'e3\'f2 \'ec\'e0 \'f0\'ee\'f6\'e0 \'e1\'e0\'fa\'f8\lang1033\f2\ltrch !\cell\pard\intbl\ltrpar\li720\qj\tx720\cf4\lang1037\f3\rtlch\'e1\'ee\'f0\'e5\'f2 \'e7\'e9\'f4\'e5\'f9 \'e7\'e3\'f9 \'e9\'fa\'f4\'f8\'f1\'ee\'e5 \'f4\'f8\'e8\'e9\'e4 \'f9\'ec \'eb\'ec \'f9\'e0\'e9\'ec\'fa\'e4\lang1033\f2\ltrch : \lang1037\f3\rtlch\'f1\'e5\'e2\lang1033\f2\ltrch , \lang1037\f3\rtlch\'ee\'f1\'f4\'f8\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f0\'e5\'f9\'e0\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e9\'e5\'e6\'ed\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f1\'e8\'e8\'e5\'f1\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'fa\'e0\'f8\'e9\'ea \'f9\'e1\'e4 \'e4\'e5\'e2\'f9\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'fa\'e0\'f8\'e9\'ea \'f9\'e1\'e4 \'f0\'f2\'f0\'fa\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f9\'f8 \'ee\'f9\'e9\'e1 \'e5\'f1\'e5\'e2 \'fa\'f9\'e5\'e1\'e4\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\qj\cf2\lang1037\f0\rtlch\'f0\'ee\'f6\'e0 \'e1\'fa\'eb\'f0\'e9\'fa \'e4\'f2\'e1\'e5\'e3\'e4 \'f9\'ec \'e4\'e0\'fa\'f8 \'e4\'e7\'e3\'f9\lang1033\f1\ltrch\cell\cell\row\trowd\trgaph108\trleft-108\trqr\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3
\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\lang1037\b\f3\rtlch\'e4\'f6\'f2\'e5\'fa \'ec\'f1\'e3\'f8 \'e4\'e9\'e5\'ed\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\li720\qj\tx720\lang1037\b0\f3\rtlch\'e4\'f6\'f2\'e4 \'ec\'f1\'e3\'f8 \'e4\'e9\'e5\'ed \'f9\'f2\'ec\'fa\'e4 \'ec\'e3\'e9\'e5\'ef \'e1\'ee\'ec\'e9\'e0\'e4 \'e0\'e5 \'f9\'e0\'e5\'e7\'e3\'e4 \'f2\'ed \'e4\'f6\'f2\'e5\'fa \'f0\'e5\'f1\'f4\'e5\'fa \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'f0\'e9\'fa\'ef \'ec\'ee\'f6\'e5\'e0 \'e0\'fa \'e4\'e4\'f6\'f2\'e4 \'e5\'e0\'fa \'e4\'e4\'e7\'ec\'e8\'e4 \'e1\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec\'e9\'ed \'f9\'ec \'e9\'f9\'e9\'e1\'e5\'fa \'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa \lang1033\f2\ltrch\par
\lang1037\f3\rtlch\'e4\'f6\'f2\'e4 \'f9\'e4\'e3\'e9\'e5\'ef \'e1\'e4 \'f0\'f2\'f6\'f8 \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'ec\'e0 \'f0\'e9\'fa\'ef \'ec\'ee\'f6\'e5\'e0 \'f4\'f8\'e8\'e9\'ed \'f2\'ec\'e9\'e4\lang1033\f2\ltrch .\par
\pard\intbl\ltrpar\li720\qr\tx720\tx1526\cell\cf4\lang1037\f3\rtlch\'e1\'ee\'f0\'e5\'f2 \'e7\'e9\'f4\'e5\'f9 \'e7\'e3\'f9 \'e9\'f4\'e5\'f8\'f1\'ee\'e5\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e1\'e0\'e5\'f4\'ef \'f0\'e5\'e7 \'ec\'e7\'e9\'f4\'e5\'f9 \'e5\'ee\'fa\'f2\'e3\'eb\'ef \'e1\'e0\'e5\'f4\'ef \'f7\'e1\'e5\'f2\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f4\'f8\'e8\'e9\'e4 \'f9\'ec \'eb\'ec \'e4\'f6\'f2\'e4 \'ec\'f1\'e3\'f8 \'e4\'e9\'e5\'ed\lang1033\f2\ltrch : \lang1037\f3\rtlch\'f1\'e5\'e2\lang1033\f2\ltrch , \lang1037\f3\rtlch\'ee\'f1\'f4\'f8\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f0\'e5\'f9\'e0\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e9\'e5\'e6\'ed\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f1\'e8\'e8\'e5\'f1\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'fa\'e0\'f8\'e9\'ea \'f9\'e1\'e4 \'e4\'e5\'e2\'f9\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'fa\'e0\'f8\'e9\'ea \'f9\'e1\'e4 \'f0\'e9\'e3\'e5\'f0\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'e5\'e5\'f2\'e3\'e4 \'f9\'e0\'ec\'e9\'e4 \'e4\'e5\'f2\'e1\'f8 \'e4\'f0\'e5\'f9\'e0\lang1033\f2\ltrch . \lang1037\f3\rtlch\'f0\'e9\'fa\'ef \'e9\'e4\'e9\'e4 \'ec\'e7\'f4\'f9 \'e1\'e0\'ee\'f6\'f2\'e5\'fa \'eb\'ee\'e4 \'f9\'e9\'e5\'fa\'f8 \'f4\'f8\'e8\'e9\'ed \'ee\'e1\'e9\'ef \'e0\'ec\'e4\lang1033\f2\ltrch .\par
\lang1037\f3\rtlch\'e0\'ed \'e4\'e4\'f6\'f2\'e4 \'ec\'f1\'e3\'f8 \'e4\'e9\'e5\'ed \'e0\'e5\'e7\'e3\'e4 \'f2\'ed \'e4\'f6\'f2\'e5\'fa \'ec\'f1\'e3\'f8 \'e4\'e9\'e5\'ed \'e0\'e7\'f8\'e5\'fa \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'f4\'f8\'e8\'e9 \'e4\'e4\'f6\'f2\'e4 \'e9\'f4\'f0\'e5 \'ec\'e4\'f6\'f2\'e4 \'f9\'f2\'ee\'e4 \'e4\'e9\'e0 \'e0\'e5\'e7\'e3\'e4 \'e5\'f9\'f2\'ec\'fa\'e4 \'ec\'e3\'e9\'e5\'ef \'e1\'ee\'ec\'e9\'e0\'e4\lang1033\f2\ltrch .\par
\pard\intbl\ltrpar\li720\qj\tx720\cell\pard\intbl\ltrpar\qj\cf2\lang1037\f0\rtlch\'f0\'ee\'f6\'e0 \'e1\'fa\'eb\'f0\'e9\'fa \'e4\'f2\'e1\'e5\'e3\'e4 \'f9\'ec \'e4\'e0\'fa\'f8 \'e4\'e7\'e3\'f9\lang1033\f1\ltrch\cell\cell\row\trowd\trgaph108\trleft-108\trqr\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3
\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\lang1037\b\f3\rtlch\'ee\'f1\'ee\'eb\'e9 \'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\li720\qj\tx720\lang1037\b0\f3\rtlch\'e1\'fa\'e5\'ea \'eb\'ec \'ee\'f1\'ee\'ea \'f9\'eb\'fa\'e1 \'e4\'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee \lang1033\f2\ltrch (\lang1037\f3\rtlch\'ee\'e7\'f7\'f8 \'e0\'e5 \'ee\'eb\'fa\'e1 \'f9\'f0\'f9\'ec\'e7 \'ec\'e7\'e1\'f8 \'eb\'f0\'f1\'fa\lang1033\f2\ltrch ) \lang1037\f3\rtlch\'ee\'f6\'e5\'e9\'ef \'e4\'e2\'e5\'f8\'ed \'f9\'f2\'e1\'e5\'f8\'e5 \'f0\'eb\'fa\'e1 \'e4\'ee\'f1\'ee\'ea\lang1033\f2\ltrch : \lang1037\f3\rtlch\'e7\'e1\'f8 \'eb\'f0\'f1\'fa \'ee\'f1\'e5\'e9\'ed\lang1033\f2\ltrch ; \lang1037\f3\rtlch\'e5\'f2\'e3\'e4 \'ee\'f1\'e5\'e9\'ee\'fa\lang1033\f2\ltrch ; \lang1037\f3\rtlch\'e0\'e5 \'f0\'e9\'f1\'e5\'e7\'e9\'ed \'f9\'e5\'f0\'e9\'ed \'e4\'ee\'e6\'eb\'e9\'f8\'e9\'ed \'e4\'ef \'e5\'f2\'e3\'e4 \'ee\'f1\'e5\'e9\'ee\'fa \'e5\'e4\'ef \'e0\'fa \'e9\'e5\'f9\'e1 \'e4\'f8\'e0\'f9 \'f9\'ec\'e4\lang1033\f2\ltrch . \lang1037\f3\rtlch\'e0\'e9 \'e0\'f4\'f9\'f8 \'ec\'e7\'f4\'f9 \'ee\'f1\'ee\'eb\'e9\'ed \'f9\'ec \'e4\'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee \'ec\'f4\'e9 \'e4\'e2\'e5\'f8\'ed \'f9\'e4\'ee\'f1\'ee\'ea \'f0\'eb\'fa\'e1 \'f2\'e1\'e5\'f8\'e5\lang1033\f2\ltrch\cell\cf4\lang1037\f3\rtlch\'f9\'ee\'e5 \'f9\'ec \'e4\'e2\'e5\'f8\'ed \'f9\'e4\'ee\'f1\'ee\'ea \'f0\'eb\'fa\'e1 \'f2\'e1\'e5\'f8\'e5 \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'e7\'e1\'f8 \'eb\'f0\'f1\'fa \'e0\'e5 \'e5\'f2\'e3\'e4 \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'e9\'e5\'f4\'e9\'f2 \'e1\'fa\'e5\'f6\'e0\'e5\'fa \'e4\'e7\'e9\'f4\'e5\'f9 \'f9\'ec \'ee\'f1\'ee\'eb\'e9 \'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee\lang1033\f2\ltrch , \lang1037\f3\rtlch\'ec\'e9\'e3 \'e4\'fa\'e0\'f8\'e9\'ea \'e5\'ee\'e7\'e1\'f8 \'e4\'ee\'f1\'ee\'ea \lang1033\f2\ltrch .\par
\lang1037\f3\rtlch\'e1\'ee\'f0\'e5\'f2 \'e7\'e9\'f4\'e5\'f9 \'e7\'e3\'f9 \'f0\'e9\'fa\'ef \'e9\'e4\'e9\'e4 \'ec\'e7\'f4\'f9 \'e0\'fa \'ee\'f1\'ee\'eb\'e9 \'e4\'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee \'ec\'f4\'e9 \'e4\'e2\'e5\'f8\'ed \'f9\'e4\'ee\'f1\'ee\'ea \'f0\'eb\'fa\'e1 \'f2\'e1\'e5\'f8\'e5 \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'e7\'e1\'f8 \'eb\'f0\'f1\'fa \'e0\'e5 \'e5\'f2\'e3\'e4\lang1033\f2\ltrch .\par
\lang1037\f3\rtlch\'e1\'ee\'f7\'f8\'e9\'ed \'f9\'e1\'e4\'ed \'ee\'f6\'e5\'e9\'ef \'e1\'ee\'f1\'ee\'ea \'e2\'ed \'f9\'ed \'e4\'e5\'e5\'f2\'e3\'e4 \'e5\'e2\'ed \'f9\'ed \'e9\'e5\lang1033\f2\ltrch "\lang1037\f3\rtlch\'f8 \'e4\'e5\'e5\'f2\'e3\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'f9\'f0\'e9\'e4\'ed \'e9\'e4\'e9\'e5 \'f2\'ec \'fa\'f7\'ef \'e4\'e2\'e5\'f8\'ee\'e9\'ed \'f9\'e4\'ee\'f1\'ee\'ea \'f0\'eb\'fa\'e1 \'f2\'e1\'e5\'f8\'e5\lang1033\f2\ltrch .\par
\pard\intbl\ltrpar\li720\qr\tx720\tx1526\cell\pard\intbl\ltrpar\qj\cf2\lang1037\f0\rtlch\'e9\'e9\'f9\'f7\'ec \'e1\'e7\'e9\'e5\'e1\lang1033\f1\ltrch , \lang1037\f0\rtlch\'e5\'e9\'e5\'eb\'f0\'f1 \'ec\'fa\'eb\'f0\'e9\'fa \'e4\'f2\'e1\'e5\'e3\'e4 \'f9\'ec \'e4\'e0\'fa\'f8 \'e4\'e7\'e3\'f9\lang1033\f1\ltrch\cell\cell\row\trowd\trgaph108\trleft-108\trqr\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3
\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\cf0\lang1037\b\f3\rtlch\'e7\'e9\'f4\'e5\'f9 \'e1\'fa\'f4\'f8\'e9\'e8 \'e4\'e7\'f7\'e9\'f7\'e4\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\li720\qj\tx720\lang1037\b0\f3\rtlch\'e1\'e0\'fa\'f8 \'e4\'e0\'e9\'f0\'e8\'f8\'f0\'e8 \'f0\'e9\'fa\'ef \'ec\'e7\'f4\'f9 \'e5\'ec\'ee\'f6\'e5\'e0 \'f0\'e5\'f1\'e7\'e9\'ed \'f9\'ec \'e4\'f6\'f2\'e5\'fa \'e7\'e5\'f7 \'f4\'f8\'e8\'e9\'e5\'fa \'f9\'e4\'e5\'f0\'e7\'e5 \'f2\'ec \'f9\'e5\'ec\'e7\'ef \'e4\'eb\'f0\'f1\'fa \lang1033\f2\ltrch (\lang1037\f3\rtlch\'eb\'e5\'ec\'ec \'fa\'e0\'f8\'e9\'ea \'e4\'f0\'e7\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e9\'e5\'e6\'ee\'e9\'ed \'e5\'ee\'f6\'e8\'f8\'f4\'e9\'ed\lang1033\f2\ltrch ); \lang1037\f3\rtlch\'e4\'f6\'f2\'e5\'fa \'e7\'e5\'f7 \'f4\'f8\'e8\'e9\'e5\'fa \'ec\'f7\'f8\'e9\'e0\'e4 \'f8\'e0\'f9\'e5\'f0\'e4\lang1033\f2\ltrch ; \lang1037\f3\rtlch\'e4\'f6\'f2\'e5\'fa \'e7\'e5\'f7 \'ee\'ee\'f9\'ec\'fa\'e9\'e5\'fa \'ec\'f7\'f8\'e9\'e0\'e4 \'f8\'e0\'f9\'e5\'f0\'e4\lang1033\f2\ltrch ; \lang1037\f3\rtlch\'e5\'e7\'e5\'f7\'e9\'ed \'f9\'e4\'fa\'f7\'e1\'ec\'e5 \'e1\'f7\'f8\'e9\'e0\'e4 \'f9\'ec\'e9\'f9\'e9\'fa \lang1033\f2\ltrch (\lang1037\f3\rtlch\'eb\'e5\'ec\'ec \'ee\'e5\'f2\'e3 \'f7\'e1\'ec\'fa \'e4\'e7\'e5\'f7\lang1033\f2\ltrch ). \lang1037\f3\rtlch\'eb\'ec \'f8\'f9\'e9\'ee\'e4 \'f0\'f4\'f8\'e3\'fa \'ec\'e7\'ec\'e5\'e8\'e9\'ef \'ee\'e4\'e0\'e7\'f8\'e5\'fa\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e5\'e0\'e9\'ef \'eb\'ec \'e3\'f8\'ea \'ec\'e1\'f8\'f8 \'ee\'e4 \'e4\'f1\'e8\'e8\'e5\'f1 \'e4\'f0\'e5\'eb\'e7\'e9 \'f9\'ec \'e4\'e4\'f6\'f2\'e4\lang1033\f2\ltrch\cell\cf4\lang1037\f3\rtlch\'fa\'e9\'e5\'e5\'f6\'f8 \'f8\'f9\'e9\'ee\'e4 \'e0\'e7\'fa \'f9\'fa\'f6\'e9\'e2 \'e1\'e0\'fa\'f8 \'e4\'e0\'e9\'f0\'e8\'f8\'f0\'e8 \'e0\'fa \'eb\'ec \'e4\'f6\'f2\'e5\'fa \'e4\'e7\'e5\'f7\lang1033\f2\ltrch . \par
\lang1037\f3\rtlch\'ec\'e2\'e1\'e9 \'eb\'ec \'e4\'f6\'f2\'fa \'e7\'e5\'f7 \'fa\'e5\'f6\'e2 \'eb\'ec \'e4\'e4\'e9\'f1\'e8\'e5\'f8\'e9\'e4 \'f9\'ec\'e4 \'e5\'eb\'ec \'e4\'f0\'fa\'e5\'f0\'e9\'ed \'e4\'f8\'ec\'e5\'e5\'f0\'e8\'e9\'e9\'ed \'ec\'e4\lang1033\f2\ltrch : \par
\pard\intbl\ltrpar\li720\qj\tx1440 - \lang1037\f3\rtlch\'e9\'e5\'e6\'ee\'e9\'e4 \'e5\'e4\'ee\'f6\'e8\'f8\'f4\'e9\'ed \'e0\'ec\'e9\'e4 \lang1033\f2\ltrch (\lang1037\f3\rtlch\'e0\'ed \'ee\'e3\'e5\'e1\'f8 \'e1\'e4\'f6\'f2\'fa \'e7\'e5\'f7 \'f4\'f8\'e8\'e9\'fa\lang1033\f2\ltrch ); \par
- \lang1037\f3\rtlch\'e4\'f0\'e5\'f1\'e7\'e9\'ed \'e4\'f9\'e5\'f0\'e9\'ed \'f9\'ec\'e4\lang1033\f2\ltrch ; \par
- \lang1037\f3\rtlch\'e4\'fa\'e0\'f8\'e9\'eb\'e9\'ed \'f9\'e1\'e4\'ed \'e4\'e9\'e0 \'e4\'e5\'f0\'e7\'e4 \'f2\'ec \'f9\'e5\'ec\'e7\'ef \'e4\'eb\'f0\'f1\'fa \lang1033\f2\ltrch (\lang1037\f3\rtlch\'e0\'ed \'ee\'e3\'e5\'e1\'f8 \'e1\'e4\'f6\'f2\'fa \'e7\'e5\'f7 \'f4\'f8\'e8\'e9\'fa\lang1033\f2\ltrch ); \par
- \lang1037\f3\rtlch\'e4\'fa\'e0\'f8\'e9\'eb\'e9\'ed \'f9\'e1\'e4\'ed \'e4\'fa\'f7\'e9\'e9\'ee\'e5 \'e3\'e9\'e5\'f0\'e9\'ed \'f2\'ec\'e9\'e4 \'e5\'e4\'f6\'e1\'f2\'e5\'fa \'f2\'ec\'e9\'e4 \'e1\'ee\'ec\'e9\'e0\'e4 \'e5\'e1\'e5\'e5\'f2\'e3\'fa \'e4\'eb\'f0\'f1\'fa\lang1033\f2\ltrch ; \par
- \lang1037\f3\rtlch\'e4\'e4\'f1\'fa\'e9\'e9\'e2\'e5\'e9\'e5\'fa \'f9\'e4\'e5\'e2\'f9\'e5 \'ec\'e4\'f6\'f2\'fa \'e4\'e7\'e5\'f7\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e4\'e3\'e9\'e5\'f0\'e9\'ed \'f2\'ec\'e9\'e4\'ef \'e5\'e4\'e4\'f6\'e1\'f2\'e5\'fa \'f2\'ec\'e9\'e4\'ef \'e1\'ee\'ec\'e9\'e0\'e4 \lang1033\f2\ltrch (\lang1037\f3\rtlch\'f8\'e0\'e4 \'f4\'e9\'f8\'e5\'e8 \'e1\'e4\'ee\'f9\'ea\lang1033\f2\ltrch ); \par
- \lang1037\f3\rtlch\'f4\'f8\'e8\'e9\'ed \'f2\'ec \'e0\'e5\'ee\'e3\'f0\'e9 \'f2\'ec\'e5\'fa \'e4\'f6\'f2\'fa \'e4\'e7\'e5\'f7 \lang1033\f2\ltrch\endash  \lang1037\f3\rtlch\'e4\'e0\'e5\'ee\'e3\'f0\'e9\'ed \'f9\'e4\'e5\'e2\'f9\'e5 \'e5\'e4\'e7\'ec\'e8\'fa \'e4\'e5\'e5\'f2\'e3\'e4 \'e1\'f2\'f0\'e9\'e9\'ef \lang1033\f2\ltrch (\lang1037\f3\rtlch\'f8\'e0\'e4 \'f4\'e9\'f8\'e5\'e8 \'e1\'e4\'ee\'f9\'ea\lang1033\f2\ltrch );  \par
- \lang1037\f3\rtlch\'ee\'e5\'f2\'e3\'e9\'ed \'f2\'fa\'e9\'e3\'e9\'e9\'ed \lang1033\f2\ltrch (\lang1037\f3\rtlch\'e0\'ed \'f7\'e9\'e9\'ee\'e9\'ed\lang1033\f2\ltrch ) \lang1037\f3\rtlch\'ec\'e3\'e9\'e5\'f0\'e9\'ed \'e5\'ec\'e4\'f6\'e1\'f2\'e4 \'e1\'ee\'ec\'e9\'e0\'e4 \'e5\'e1\'e5\'e5\'f2\'e3\'e5\'fa\lang1033\f2\ltrch .\par
\pard\intbl\ltrpar\li720\qj\tx720\lang1037\f3\rtlch\'fa\'e4\'e9\'e9\'f0\'e4 \'e4\'f4\'f0\'e9\'e5\'fa \'ec\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec\'e9\'ed \'f9\'ec \'e9\'f9\'e9\'e1\'e5\'fa \'e4\'ee\'ec\'e9\'e0\'e4 \'e5\'e4\'e5\'e5\'f2\'e3\'e5\'fa \'f9\'e1\'e4\'ef \'e3\'f0\'e5 \'e1\'e4\'f6\'f2\'fa \'e4\'e7\'e5\'f7 \'e5\'e1\'e4\'f1\'fa\'e9\'e9\'e2\'e5\'e9\'e5\'fa \'ec\'e4 \'e5\'e4\'f6\'e1\'e9\'f2\'e5 \'f2\'ec \'eb\'ea\lang1033\f2\ltrch ; \lang1037\f3\rtlch\'ec\'ee\'f1\'ee\'eb\'e9\'ed \'e4\'ee\'f4\'f8\'e8\'e9\'ed \'e0\'fa \'e4\'f2\'ec\'e5\'fa \'e4\'fa\'f7\'f6\'e9\'e1\'e9\'fa \'f9\'ec \'e4\'e7\'e5\'f7 \'e5\'ec\'e3\'e9\'e5\'f0\'e9 \'e4\'e5\'e5\'f2\'e3\'e4 \'f9\'f2\'f1\'f7\'e5 \'e1\'f1\'e5\'e2\'e9\'e4 \'e6\'e5\lang1033\f2\ltrch ; \lang1037\f3\rtlch\'e5\'ec\'e4\'f6\'e1\'f2\'e5\'fa \'e4\'f8\'ec\'e5\'e5\'f0\'e8\'e9\'e5\'fa \'e1\'ee\'ec\'e9\'e0\'e4 \'e1\'f2\'ee\'e5\'e3 \lang1033\f2\ltrch "\lang1037\f3\rtlch\'e4\'f6\'e1\'f2\'e5\'fa \'e0\'ec\'f7\'e8\'f8\'e5\'f0\'e9\'e5\'fa \'e1\'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa\lang1033\f2\ltrch " \lang1037\f3\rtlch\'e1\'e0\'fa\'f8 \'e4\'e0\'e9\'f0\'e8\'f8\'f0\'e8\lang1033\f2\ltrch .\cell\pard\intbl\ltrpar\qj\cf2\f1  \lang1037\f0\rtlch\'f0\'ee\'f6\'e0 \'e1\'fa\'eb\'f0\'e9\'fa \'e4\'f2\'e1\'e5\'e3\'e4 \'f9\'ec \'e4\'e0\'fa\'f8 \'e4\'e7\'e3\'f9\cf4\lang1033\f1\ltrch\cell\cell\row\trowd\trgaph108\trleft-108\trqr\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3
\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\cf2\lang1037\b\f3\rtlch\'e4\'f1\'fa\'e9\'e9\'e2\'e5\'e9\'e5\'fa \'ec\'e4\'f6\'f2\'e5\'fa \'e7\'e5\'f7\cf4\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\li720\qj\tx720\cf2\lang1037\b0\f3\rtlch\'e4\'f1\'fa\'e9\'e9\'e2\'e5\'e9\'e5\'fa \'f9\'e4\'e5\'e2\'f9\'e5 \'ec\'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa \'ec\'e4\'f6\'f2\'e5\'fa \'e7\'e5\'f7 \'f0\'e9\'fa\'ef \'ec\'ee\'f6\'e5\'e0 \'f8\'f7 \'e1\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec\'e9\'ed \'f9\'ec \'e9\'f9\'e9\'e1\'e5\'fa \'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e5\'e0\'fa \'f4\'f8\'e8\'e9 \'e4\'e4\'f6\'e1\'f2\'e4 \'e1\'f2\'ee\'e5\'e3 \lang1033\f2\ltrch "\lang1037\f3\rtlch\'e4\'f6\'e1\'f2\'e5\'fa \'e0\'ec\'f7\'e8\'f8\'e5\'f0\'e9\'e5\'fa \'e1\'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa\lang1033\f2\ltrch " \endash  \lang1037\f3\rtlch\'ec\'ec\'e0 \'eb\'ec \'f7\'e9\'f9\'e5\'f8 \'e1\'e9\'ef \'e4\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec \'ec\'e4\'f6\'e1\'f2\'e4\cf4\lang1033\f2\ltrch\cell\lang1037\f3\rtlch\'e1\'ee\'f1\'e2\'f8\'fa \'fa\'f4\'f8\'e9\'e8 \'e4\'e7\'f7\'e9\'f7\'e4 \'e9\'f4\'e5\'f8\'e8\'e5 \'e4\'e4\'f1\'fa\'e9\'e9\'e2\'e5\'e9\'e5\'fa \'f9\'e4\'e5\'e2\'f9\'e5 \'ec\'eb\'ec \'e4\'f6\'f2\'fa \'e7\'e5\'f7 \'e5\'e4\'e4\'e7\'ec\'e8\'e4 \'e1\'f2\'f0\'e9\'e9\'ef \'e4\'e4\'f1\'fa\'e9\'e9\'e2\'e5\'fa\lang1033\f2\ltrch , \lang1037\f3\rtlch\'fa\'e5\'ea \'e4\'f4\'f0\'e9\'e5\'fa \'ec\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec\'e9\'ed \'e4\'ee\'fa\'e0\'e9\'ee\'e9\'ed \'f9\'ec \'e9\'f9\'e9\'e1\'e5\'fa \'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa \'e5\'ec\'e4\'f6\'e1\'f2\'e5\'fa \'e4\'f8\'ec\'e5\'e5\'f0\'e8\'e9\'e5\'fa \'e1\'f2\'ee\'e5\'e3 \lang1033\f2\ltrch "\lang1037\f3\rtlch\'e4\'f6\'e1\'f2\'e5\'fa \'e0\'ec\'f7\'e8\'f8\'e5\'f0\'e9\'fa \'e1\'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa\lang1033\f2\ltrch ".\cell\pard\intbl\ltrpar\qj\cf2\lang1037\f0\rtlch\'f0\'ee\'f6\'e0 \'e1\'fa\'eb\'f0\'e9\'fa \'e4\'f2\'e1\'e5\'e3\'e4 \'f9\'ec \'e4\'e0\'fa\'f8 \'e4\'e7\'e3\'f9 \'e1\'ee\'f1\'e2\'f8\'fa \'e4\'e8\'e9\'f4\'e5\'ec \'e1\'fa\'f4\'f8\'e9\'e8 \'e4\'e7\'f7\'e9\'f7\'e4\lang1033\f1\ltrch\cell\cf4\cell\row\trowd\trgaph108\trleft-108\trqr\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3
\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\cf2\b\f2 "\lang1037\f3\rtlch\'e4\'f6\'f2\'e5\'fa \'e7\'e5\'f7 \'fa\'f7\'f6\'e9\'e1\'e9\'e5\'fa\lang1033\f2\ltrch "\cf4\cell\pard\intbl\ltrpar\li720\qj\tx720\cf2\lang1037\b0\f3\rtlch\'e4\'f0\'fa\'e5\'f0\'e9\'ed \'e4\'f0\'e5\'e2\'f2\'e9\'ed \'ec\'f9\'e0\'ec\'e4 \'e0\'ed \'e4\'f6\'f2\'fa \'e7\'e5\'f7 \'f4\'f8\'e8\'e9\'fa \'ee\'f1\'e5\'e9\'ee\'fa \'e4\'e9\'e0 \'e1\'f2\'ec\'fa \lang1033\f2\ltrch "\lang1037\f3\rtlch\'f2\'ec\'e5\'fa \'fa\'f7\'f6\'e9\'e1\'e9\'fa\lang1033\f2\ltrch " \lang1037\f3\rtlch\'ec\'e0 \'ee\'fa\'f4\'f8\'f1\'ee\'e9\'ed \'e1\'e0\'e5\'f4\'ef \'ee\'f1\'e5\'e3\'f8\lang1033\f2\ltrch . \lang1037\f3\rtlch\'ec\'f2\'fa\'e9\'ed \'f0\'e9\'fa\'ef \'ec\'ee\'f6\'e5\'e0 \'f0\'fa\'e5\'f0\'e9\'ed \'e7\'ec\'f7\'e9\'e9\'ed \'e1\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec\'e9\'ed \'f9\'ec \'e9\'f9\'e9\'e1\'e5\'fa \'e5\'ee\'ec\'e9\'e0\'fa \'e4\'eb\'f0\'f1\'fa \'e5\'e5\'f2\'e3\'e5\'fa\'e9\'e4\lang1033\f2\ltrch .\par
\cf4\cell\lang1037\f3\rtlch\'e1\'ee\'f1\'e2\'f8\'fa \'fa\'f4\'f8\'e9\'e8 \'e4\'e7\'f7\'e9\'f7\'e4 \'e4\'ee\'e5\'f6\'f2 \'e9\'f4\'e5\'f8\'e8\lang1033\f2\ltrch , \lang1037\f3\rtlch\'ec\'e2\'e1\'e9 \'eb\'ec \'e4\'f6\'f2\'fa \'e7\'e5\'f7 \'f4\'f8\'e8\'e9\'fa\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e0\'ed \'ee\'f9\'f8\'e3 \'e4\'e0\'e5\'f6\'f8 \'e4\'e2\'e9\'f9 \'e4\'f2\'f8\'eb\'fa \'f2\'ec\'e5\'fa \'fa\'f7\'f6\'e9\'e1\'e9\'fa \'ec\'e5\'e5\'f2\'e3\'e4 \'e1\'f2\'f0\'e9\'e9\'ef \'e4\'f6\'f2\'fa \'e4\'e7\'e5\'f7\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e0\'ed \'e4\'e5\'e2\'f9\'e4 \'e4\'f2\'f8\'eb\'fa \'f2\'ec\'e5\'fa \'fa\'f7\'f6\'e9\'e1\'e9\'fa \'f0\'e5\'f1\'f4\'fa \'f9\'ec \'e4\'ee\'ee\lang1033\f2\ltrch "\lang1037\f3\rtlch\'ee \'e5\'ee\'e4 \'e4\'e9\'e9\'fa\'e4 \'e4\'e7\'ec\'e8\'fa \'e4\'e5\'e5\'f2\'e3\'e4 \'e1\'f1\'e5\'e2\'e9\'e4 \'e6\'e5\lang1033\f2\ltrch , \lang1037\f3\rtlch\'fa\'e5\'ea \'e4\'f4\'f0\'e9\'e5\'fa \'ec\'ee\'f1\'ee\'eb\'e9 \'e4\'f2\'f8\'eb\'fa \'e4\'f2\'ec\'e5\'fa \'e4\'ee\'fa\'e0\'e9\'ee\'e9\'ed \'e5\'ec\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec\'e9\'ed \'e4\'ee\'fa\'e0\'e9\'ee\'e9\'ed \'f9\'ec \'e3\'e9\'e5\'f0\'e9 \'e4\'e5\'e5\'f2\'e3\'e4\lang1033\f2\ltrch\cell\pard\intbl\ltrpar\qj\cf2\lang1037\f0\rtlch\'f0\'ee\'f6\'e0 \'e1\'fa\'eb\'f0\'e9\'fa \'e4\'f2\'e1\'e5\'e3\'e4 \'f9\'ec \'e4\'e0\'fa\'f8 \'e4\'e7\'e3\'f9 \'e1\'ee\'f1\'e2\'f8\'fa \'e4\'e8\'e9\'f4\'e5\'ec \'e1\'fa\'f4\'f8\'e9\'e8 \'e4\'e7\'f7\'e9\'f7\'e4\lang1033\f1\ltrch\cell\cf4\cell\row\trowd\trgaph108\trleft-108\trqr\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3
