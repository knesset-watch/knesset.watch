\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx1286\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx4958\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx8378\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx12338\clbrdrl\brdrw15\brdrs\clbrdrt\brdrw15\brdrs\clbrdrr\brdrw15\brdrs\clbrdrb\brdrw15\brdrs \cellx14318\pard\intbl\ltrpar\qj\lang1037\b\f3\rtlch\'f8\'e9\'f9\'e5\'ed \'f0\'e5\'eb\'e7\'e5\'fa \'e7\'e1\'f8\'e9 \'e4\'eb\'f0\'f1\'fa \ul\'e1\'e5\'e5\'f2\'e3\'e5\'fa \'e4\'eb\'f0\'f1\'fa\lang1033\ulnone\f2\ltrch\cell\pard\intbl\ltrpar\li720\qj\tx720\lang1037\b0\f3\rtlch\'e9\'f9 \'f8\'e9\'f9\'e5\'ed \'f9\'ec \'e7\'e1\'f8\'e9 \'e4\'eb\'f0\'f1\'fa \'f9\'f0\'eb\'e7\'e5 \'e1\'e9\'f9\'e9\'e1\'fa \'e5\'f2\'e3\'e4 \'ee\'f1\'e5\'e9\'ee\'fa\lang1033\f2\ltrch , \lang1037\f3\rtlch\'e5\'f8\'e9\'f9\'e5\'ed \'e6\'e4 \'ee\'e5\'f4\'e9\'f2 \'e1\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec \'f9\'ec \'e0\'e5\'fa\'e4 \'e9\'f9\'e9\'e1\'e4\lang1033\f2\ltrch . \lang1037\f3\rtlch\'e0\'e9\'ef \'f4\'e9\'f8\'e5\'e8 \'ee\'fa\'e9 \'e4\'f6\'e8\'f8\'f3 \'eb\'ec \'e7\'e1\'f8 \'eb\'f0\'f1\'fa \'ec\'e9\'f9\'e9\'e1\'e4\lang1033\f2\ltrch , \lang1037\f3\rtlch\'ee\'fa\'e9 \'f2\'e6\'e1 \'e0\'e5\'fa\'e4 \'e5\'eb\'ee\'e4 \'e6\'ee\'ef \'f0\'eb\'e7 \'e1\'e4\lang1033\f2\ltrch .\cell\cf3\lang1037\f3\rtlch\'e9\'fa\'e1\'f6\'f2 \'f8\'e9\'f9\'e5\'ed \'f9\'ec \'e6\'ee\'f0\'e9 \'e4\'eb\'f0\'e9\'f1\'e4 \'e5\'e4\'e9\'f6\'e9\'e0\'e4 \'f9\'ec \'e4\'e7\'e1\'f8\'e9 \'eb\'f0\'f1\'fa \'ee\'e9\'f9\'e9\'e1\'e5\'fa \'e5\'f2\'e3\'e5\'fa \'e4\'eb\'f0\'f1\'fa \'e1\'f4\'f8\'e5\'e8\'e5\'f7\'e5\'ec\'e9\'ed \'f9\'ec \'e4\'e9\'f9\'e9\'e1\'e5\'fa\lang1033\f2\ltrch , \lang1037\f3\rtlch\'eb\'ea \'f9\'f0\'e9\'fa\'ef \'e9\'e4\'e9\'e4 \'ec\'e3\'f2\'fa \'e1\'e3\'e9\'e5\'f7 \'e1\'e0\'e9\'ec\'e5 \'e7\'ec\'f7\'e9\'ed \'f9\'ec \'e4\'e9\'f9\'e9\'e1\'e4 \'eb\'ec \'e7\'e1\'f8 \'eb\'f